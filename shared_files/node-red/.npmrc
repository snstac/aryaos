# node-red is the HOST runtime (installed globally by the upstream
# update-nodejs-and-nodered-deb installer), not a palette dependency. Without
# this, npm >=7 auto-installs the contrib nodes' `node-red` peer, dragging a
# full nested copy of Node-RED (node-red-admin, a bundled npm, js-yaml/multer/
# undici, ...) into .node-red — ~355 packages of redundant, vuln-bearing bloat.
# legacy-peer-deps keeps peer deps out of the palette tree, matching how the
# Node-RED palette manager itself installs nodes.
legacy-peer-deps=true
