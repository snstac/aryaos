#!/usr/bin/python3
"""CGI wrapper for AryaOS TAK connection package or enrollment URL import."""

import configparser
from email.parser import BytesParser
from email.policy import default
import json
import os
import socket
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

SOCKET_PATH = "/run/aryaos/tak-dp-import.sock"
MAX_UPLOAD_BYTES = 12 * 1024 * 1024
MAX_ENROLLMENT_URL_BYTES = 8192
TLS_DIR = Path("/etc/aryaos/tls")
ARYAOS_CONFIG = Path("/etc/aryaos/aryaos-config.txt")
CHARONTAK_INI = Path("/etc/charontak.ini")


def response(status, payload):
    sys.stdout.write(f"Status: {status}\r\n")
    sys.stdout.write("Content-Type: application/json; charset=utf-8\r\n")
    sys.stdout.write("Cache-Control: no-store\r\n")
    sys.stdout.write("X-Content-Type-Options: nosniff\r\n")
    sys.stdout.write("\r\n")
    sys.stdout.write(json.dumps(payload, sort_keys=True))
    sys.stdout.write("\n")


def error(status, message):
    response(status, {"ok": False, "error": message})
    raise SystemExit(0)


def _read_kv(path):
    values = {}
    try:
        for raw in path.read_text(encoding="utf-8").splitlines():
            line = raw.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            values[key.strip()] = value.strip().strip("\"'")
    except OSError:
        pass
    return values


def _charontak_lane():
    cfg = configparser.RawConfigParser()
    cfg.optionxform = str
    try:
        cfg.read(CHARONTAK_INI)
    except configparser.Error:
        return {}
    section = "lane:local-to-takserver"
    if not cfg.has_section(section):
        section = "lane:mesh-to-takserver"
    if not cfg.has_section(section):
        return {}
    return {key: value for key, value in cfg.items(section)}


def _service_active(unit):
    try:
        run = subprocess.run(
            ["/usr/bin/systemctl", "is-active", unit],
            check=False,
            capture_output=True,
            text=True,
            timeout=3,
        )
        return (run.stdout or "").strip()
    except (OSError, subprocess.TimeoutExpired):
        return "unknown"


def _mtime_iso(paths):
    mtimes = []
    for path in paths:
        try:
            mtimes.append(path.stat().st_mtime)
        except OSError:
            continue
    if not mtimes:
        return ""
    return datetime.fromtimestamp(max(mtimes), tz=timezone.utc).isoformat(timespec="seconds")


def enrollment_status():
    kv = _read_kv(ARYAOS_CONFIG)
    lane = _charontak_lane()
    cert = TLS_DIR / "client.pem"
    key = TLS_DIR / "client.key"
    ca = TLS_DIR / "ca.pem"
    socket_ready = os.path.exists(SOCKET_PATH) and stat_is_socket(SOCKET_PATH)
    service_state = _service_active("aryaos-tak-dp-importd.service")
    cot_url = lane.get("egress_cot_url") or kv.get("COT_URL") or ""
    lane_enabled = lane.get("enabled", "").lower() == "true"
    tls_ready = cert.exists() and key.exists() and ca.exists()
    takserver_target = cot_url.startswith(("tls://", "ssl://", "tcp://"))
    configured = bool(lane_enabled and takserver_target and (tls_ready or cot_url.startswith("tcp://")))
    detail = ""
    if configured:
        detail = "Charontak local-to-TAK Server lane is enabled."
    elif not lane_enabled:
        detail = "Charontak local-to-TAK Server lane is not enabled."
    elif not takserver_target:
        detail = "No TAK Server target is configured."
    elif not tls_ready:
        detail = "TAK Server TLS material is incomplete."
    return {
        "configured": configured,
        "import_service_ready": bool(socket_ready),
        "import_service_state": service_state,
        "cot_url": cot_url,
        "detail": detail,
        "tls": {
            "client_cert": cert.exists(),
            "client_key": key.exists(),
            "ca": ca.exists(),
        },
        "last_updated": _mtime_iso([CHARONTAK_INI, ARYAOS_CONFIG, cert, key, ca]),
    }


def stat_is_socket(path):
    try:
        import stat

        return stat.S_ISSOCK(os.stat(path).st_mode)
    except OSError:
        return False


def parse_upload():
    try:
        content_length = int(os.environ.get("CONTENT_LENGTH") or "0")
    except ValueError:
        content_length = 0
    if content_length <= 0:
        error("400 Bad Request", "No upload body")
    if content_length > MAX_UPLOAD_BYTES:
        error("413 Payload Too Large", "Connection package is too large")
    content_type = os.environ.get("CONTENT_TYPE", "")
    if "multipart/form-data" not in content_type:
        error("400 Bad Request", "Expected multipart/form-data")

    body = sys.stdin.buffer.read(content_length)
    if len(body) > MAX_UPLOAD_BYTES:
        error("413 Payload Too Large", "Connection package is too large")
    raw = (
        f"Content-Type: {content_type}\r\n"
        "MIME-Version: 1.0\r\n"
        "\r\n"
    ).encode("utf-8") + body
    msg = BytesParser(policy=default).parsebytes(raw)
    if not msg.is_multipart():
        error("400 Bad Request", "Invalid multipart upload")
    enrollment_url = ""
    for part in msg.iter_parts():
        if part.get_content_disposition() != "form-data":
            continue
        field_name = part.get_param("name", header="content-disposition")
        if field_name == "enrollment_url":
            enrollment_url = (part.get_content() or "").strip()
            if len(enrollment_url.encode("utf-8")) > MAX_ENROLLMENT_URL_BYTES:
                error("413 Payload Too Large", "Enrollment URL is too large")
            continue
        if field_name == "package":
            filename = part.get_param("filename", header="content-disposition") or ""
            payload = part.get_payload(decode=True) or b""
            if payload:
                if len(payload) > MAX_UPLOAD_BYTES:
                    error("413 Payload Too Large", "Connection package is too large")
                return {"type": "package", "filename": filename, "payload": payload}
    if enrollment_url:
        return {"type": "enrollment_url", "enrollment_url": enrollment_url}
    error("400 Bad Request", "Missing package file or enrollment URL field")


def main():
    method = os.environ.get("REQUEST_METHOD", "GET").upper()
    if method == "GET":
        response(
            "200 OK",
            {
                "ok": True,
                "accept": [".zip", ".dpk"],
                "accept_enrollment_url": True,
                "max_bytes": MAX_UPLOAD_BYTES,
                "max_enrollment_url_bytes": MAX_ENROLLMENT_URL_BYTES,
                "enrollment_status": enrollment_status(),
            },
        )
        return
    if method != "POST":
        error("405 Method Not Allowed", "Use POST")
    upload = parse_upload()
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
            sock.settimeout(120)
            sock.connect(SOCKET_PATH)
            if upload["type"] == "enrollment_url":
                sock.sendall(
                    json.dumps(
                        {"type": "enrollment_url", "enrollment_url": upload["enrollment_url"]},
                        separators=(",", ":"),
                    ).encode("utf-8")
                )
            else:
                sock.sendall(upload["payload"])
            sock.shutdown(socket.SHUT_WR)
            chunks = []
            while True:
                chunk = sock.recv(65536)
                if not chunk:
                    break
                chunks.append(chunk)
        raw = b"".join(chunks).decode("utf-8", errors="replace")
        try:
            payload = json.loads(raw)
        except json.JSONDecodeError:
            error("500 Internal Server Error", "Importer returned invalid JSON")
        if not payload.get("ok"):
            error("400 Bad Request", payload.get("error") or "Import failed")
        response("200 OK", payload)
    except (OSError, TimeoutError) as exc:
        if isinstance(exc, FileNotFoundError):
            error("503 Service Unavailable", "Import service is not running")
        error("504 Gateway Timeout", "Import timed out")


if __name__ == "__main__":
    main()
