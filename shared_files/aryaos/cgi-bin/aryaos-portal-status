def cgi_fail(status_line, body):
    sys.stdout.write(f"Status: {status_line}\r\n")
    sys.stdout.write("Content-Type: text/plain; charset=utf-8\r\n")
    sys.stdout.write("Cache-Control: no-store\r\n")
    sys.stdout.write("\r\n")
    sys.stdout.write(body)
    if not body.endswith("\n"):
        sys.stdout.write("\n")


def run(argv, timeout=8):
    try:
        r = subprocess.run(
            argv,
            check=False,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
        return (r.stdout or "").strip(), r.returncode, (r.stderr or "").strip()
    except OSError as e:
        return "", -1, str(e)
    except subprocess.TimeoutExpired:
        return "", -1, "command timed out"


def run_gpspipe(argv, timeout=8):
    """Like run(), but keep partial stdout on TimeoutExpired so we can still parse."""
    try:
        r = subprocess.run(
            argv,
            check=False,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
        return (r.stdout or "").strip(), r.returncode, (r.stderr or "").strip()
    except OSError as e:
        return "", -1, str(e)
    except subprocess.TimeoutExpired as e:
        partial = (e.stdout or "").strip() if e.stdout else ""
        hint = "gpspipe timed out (no JSON yet)" if not partial else "gpspipe timed out (using partial capture)"
        return partial, -1, hint


def primary_ip():
    out, _, _ = run([IP, "-4", "route", "get", "8.8.8.8"])
    parts = out.split()
    if "src" in parts:
        i = parts.index("src")
        if i + 1 < len(parts):
            return parts[i + 1].strip()
    out, _, _ = run([IP, "-4", "-br", "addr", "show", "scope", "global"])
    for line in out.splitlines():
        line = line.strip()
        if not line or line.startswith("lo"):
            continue
        bits = line.split()
        if len(bits) >= 3 and "/" in bits[2]:
            return bits[2].split("/")[0]
        if len(bits) >= 2:
            for tok in bits[2:]:
                if tok and tok[0].isdigit():
                    return tok.split("/")[0]
    return ""


def _probe_uptime():
    out, _, _ = run([UPTIME, "-p"])
    return (out or "").strip() or "—"


def _probe_ipv4_block():
    out, _, _ = run([IP, "-4", "-br", "addr", "show", "scope", "global"])
    return (out or "").strip() if out else "(unavailable)"


def _read_loadavg():
    try:
        with open("/proc/loadavg", encoding="utf-8") as f:
            parts = f.read().split()
        if len(parts) < 3:
            return None
        return {
            "1": round(float(parts[0]), 2),
            "5": round(float(parts[1]), 2),
            "15": round(float(parts[2]), 2),
        }
    except (OSError, ValueError):
        return None


def _read_meminfo():
    try:
        info = {}
        with open("/proc/meminfo", encoding="utf-8") as f:
            for line in f:
                if ":" not in line:
                    continue
                key, _, val = line.partition(":")
                info[key.strip()] = int(val.strip().split()[0])
        total_kb = info.get("MemTotal")
        avail_kb = info.get("MemAvailable")
        if total_kb is None or total_kb <= 0:
            return None
        total_mb = round(total_kb / 1024)
        available_mb = round(avail_kb / 1024) if avail_kb is not None else None
        used_pct = None
        if available_mb is not None:
            used_pct = round(100.0 * (total_kb - avail_kb) / total_kb)
        return {
            "total_mb": total_mb,
            "available_mb": available_mb,
            "used_pct": used_pct,
        }
    except (OSError, ValueError):
        return None


def _cpu_temp_c():
    out, code, _ = run([VCGENCMD, "measure_temp"], timeout=3)
    if code == 0 and out.startswith("temp="):
        m = re.match(r"temp=([\d.]+)", out)
        if m:
            return float(m.group(1))
    try:
        with open(THERMAL_ZONE0, encoding="utf-8") as f:
            millideg = int(f.read().strip())
        return round(millideg / 1000.0, 1)
    except (OSError, ValueError):
        return None


def _throttle_labels(mask, bit_base):
    labels = []
    for bit in range(4):
        b = bit_base + bit
        if mask & (1 << bit) and b in THROTTLE_ISSUES:
            labels.append(THROTTLE_ISSUES[b])
    return labels


def _throttle_state(current, history):
    if any(
        x in current
        for x in (
            "Under-voltage detected",
            "Currently throttled",
        )
    ):
        return "bad"
    if any(
        x in history
        for x in (
            "Under-voltage has occurred",
            "Throttling has occurred",
        )
    ):
        return "warn"
    if current or history:
        return "warn"
    return "ok"


def _parse_throttled():
    out, code, err = run([VCGENCMD, "get_throttled"], timeout=3)
    if code != 0 or not out:
        return None, err or f"vcgencmd exit {code}"
    m = re.search(r"0x([0-9a-fA-F]+)", out)
    if not m:
        return None, "unparseable get_throttled output"
    raw = int(m.group(1), 16)
    current = _throttle_labels(raw & 0xF, 0)
    history = _throttle_labels((raw >> 16) & 0xF, 16)
    return {
        "raw": raw,
        "state": _throttle_state(current, history),
        "current": current,
        "history": history,
    }, None


def gather_system():
    out = {
        "ok": True,
        "error": None,
        "cpu_temp_c": None,
        "load": None,
        "mem": None,
        "throttle": None,
    }
    errors = []

    out["load"] = _read_loadavg()
    out["mem"] = _read_meminfo()

    temp = _cpu_temp_c()
    if temp is not None:
        out["cpu_temp_c"] = temp
    else:
        errors.append("cpu temperature unavailable")

    throttle, terr = _parse_throttled()
    if throttle is not None:
        out["throttle"] = throttle
    elif terr:
        errors.append(terr)

    if errors and out["load"] is None and out["mem"] is None:
        out["ok"] = False
        out["error"] = "; ".join(errors)
    elif errors:
        out["error"] = "; ".join(errors)
        if out["cpu_temp_c"] is None and out["throttle"] is None:
            out["ok"] = False

    return out


