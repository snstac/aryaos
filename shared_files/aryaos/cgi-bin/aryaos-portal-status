#!/usr/bin/python3
# CGI: JSON host/network + GNSS (gpsd) + radio/RF inventory for the HTTPS landing page.
#
# Uses absolute paths (lighttpd often sets a minimal PATH) and /usr/bin/python3.
# www-data must be in the "gpsd" group to run gpspipe against /run/gpsd.sock.
# www-data must be in the "video" group to run vcgencmd (temp / throttling) on Raspberry Pi.
#
# systemd's lighttpd unit sets RestrictAddressFamilies without AF_NETLINK by default;
# iproute2 "ip" needs AF_NETLINK — see systemd drop-in aryaos-netlink.conf.
#
