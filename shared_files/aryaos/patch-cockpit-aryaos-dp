#!/usr/bin/python3
"""Add AryaOS TAK data package import UI to the packaged cockpit-aryaos page."""

from pathlib import Path

PLUGIN_DIR = Path("/usr/share/cockpit/aryaos")
INDEX = PLUGIN_DIR / "index.html"
JS = PLUGIN_DIR / "aryaos.js"
CSS = PLUGIN_DIR / "aryaos.css"


DP_CARD = """    <section class="aos-card" id="card-dp">
      <h2>TAK connection data package</h2>
      <p class="aos-hint">Import an ATAK/iTAK connection data package generated by <code>pytak dp</code> or TAK Server enrollment. AryaOS installs the package certs under <code>/etc/aryaos/tls</code> and enables Charontak forwarding to the package TAK Server.</p>
      <div class="aos-upload-row">
        <label class="aos-file-label">Connection package (.zip / .dpk)
          <input type="file" id="dp-file" accept=".zip,.dpk,application/zip,application/octet-stream">
        </label>
        <button class="aos-btn" id="btn-dp-upload">Import package</button>
      </div>
      <span id="dp-status" class="aos-status"></span>
    </section>

"""

DP_JS = """
/* --- ATAK/iTAK data package import --- */
function importDataPackage() {
    const el = $("dp-status");
    const fileInput = $("dp-file");
    const file = fileInput && fileInput.files && fileInput.files[0];
    if (!file) {
        setStatus(el, "Choose a .zip or .dpk connection package first.", false);
        return;
    }
    const body = new FormData();
    body.append("package", file);
    el.textContent = "Importing package...";
    el.className = "aos-status";
    fetch("/cgi-bin/aryaos-tak-dp-upload", {
        method: "POST",
        body,
        credentials: "same-origin",
        cache: "no-store",
    })
        .then((r) => r.json().then((payload) => {
            if (!r.ok || !payload.ok) throw new Error(payload.error || ("HTTP " + r.status));
            return payload;
        }))
        .then((payload) => {
            const target = payload.cot_url || "TAK Server";
            setStatus(el, "Imported " + target + "; Charontak forwarding updated.", true);
            showCurrentTls();
            refreshServices();
        })
        .catch((ex) => setStatus(el, "Import failed: " + (ex.message || ex), false));
}

"""

DP_CSS = """
.aos-upload-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: end; }
.aos-file-label { flex: 1 1 18rem; }
.aos-file-label input[type="file"] { display: block; margin-top: 0.3rem; font-weight: 400; }
"""


def patch_index():
    text = INDEX.read_text(encoding="utf-8")
    if 'id="card-dp"' in text:
        return False
    marker = '    <section class="aos-card" id="card-services">\n'
    if marker not in text:
        raise RuntimeError(f"{INDEX}: services card marker not found")
    INDEX.write_text(text.replace(marker, DP_CARD + marker), encoding="utf-8")
    return True


def patch_js():
    text = JS.read_text(encoding="utf-8")
    changed = False
    if "function importDataPackage" not in text:
        marker = "/* --- Services card --- */"
        if marker not in text:
            raise RuntimeError(f"{JS}: services marker not found")
        text = text.replace(marker, DP_JS + marker)
        changed = True
    listener = '$("btn-tls-upload").addEventListener("click", installTls);'
    dp_listener = '$("btn-dp-upload").addEventListener("click", importDataPackage);'
    if dp_listener not in text:
        if listener not in text:
            raise RuntimeError(f"{JS}: TLS upload listener marker not found")
        text = text.replace(listener, listener + "\n" + dp_listener)
        changed = True
    if changed:
        JS.write_text(text, encoding="utf-8")
    return changed


def patch_css():
    text = CSS.read_text(encoding="utf-8")
    if ".aos-upload-row" in text:
        return False
    CSS.write_text(text.rstrip() + "\n" + DP_CSS, encoding="utf-8")
    return True


def main():
    if not PLUGIN_DIR.is_dir():
        raise SystemExit("cockpit-aryaos plugin directory not found; package not installed?")
    changed = [patch_index(), patch_js(), patch_css()]
    for path in (INDEX, JS, CSS):
        path.chmod(0o644)
    print("patched cockpit-aryaos data package UI" if any(changed) else "cockpit-aryaos data package UI already present")


if __name__ == "__main__":
    main()
