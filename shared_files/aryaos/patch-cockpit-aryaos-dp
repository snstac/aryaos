DP_CSS = """
.aos-status-table { margin: 0.7rem 0 1rem; }
.aos-status-table td:first-child { width: 12rem; color: var(--aos-muted); }
.aos-upload-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: end; }
.aos-file-label { flex: 1 1 18rem; }
.aos-file-label input[type="file"] { display: block; margin-top: 0.3rem; font-weight: 400; }
.aos-file-label textarea { display: block; box-sizing: border-box; width: 100%; margin-top: 0.3rem; font: inherit; font-family: monospace; }
"""


def patch_index():
    text = INDEX.read_text(encoding="utf-8")
    changed = False
    services_marker = '    <section class="aos-card" id="card-services">\n'
    if 'id="card-dp"' in text:
        if 'id="tak-enrollment-table"' not in text:
            marker = '      <div class="aos-upload-row">\n        <label class="aos-file-label">One-time enrollment URL'
            insert = '      <table class="aos-table aos-status-table" id="tak-enrollment-table"><tbody></tbody></table>\n'
            if marker not in text:
                raise RuntimeError(f"{INDEX}: TAK connection status marker not found")
            text = text.replace(marker, insert + marker)
            changed = True
        if 'id="btn-tak-refresh"' not in text:
            marker = '        <button class="aos-btn" id="btn-dp-upload">Import package</button>'
            if marker not in text:
                raise RuntimeError(f"{INDEX}: data package upload button marker not found")
            text = text.replace(marker, marker + '\n        <button class="aos-btn" id="btn-tak-refresh">Refresh status</button>')
            changed = True
        if 'id="dp-enrollment-url"' not in text:
            marker = '      <div class="aos-upload-row">\n        <label class="aos-file-label">Connection package (.zip / .dpk)'
            insert = """      <div class="aos-upload-row">
        <label class="aos-file-label">One-time enrollment URL
          <textarea id="dp-enrollment-url" rows="3" placeholder="tak://com.atakmap.app/enroll?host=...&amp;username=...&amp;token=..."></textarea>
        </label>
        <button class="aos-btn" id="btn-enrollment-import">Enroll</button>
      </div>
"""
            if marker not in text:
                raise RuntimeError(f"{INDEX}: data package upload row marker not found")
            text = text.replace(marker, insert + marker)
            changed = True
    else:
        if services_marker not in text:
            raise RuntimeError(f"{INDEX}: services card marker not found")
        text = text.replace(services_marker, DP_CARD + services_marker)
        changed = True
    if 'id="card-neighbors"' not in text:
        if services_marker not in text:
            raise RuntimeError(f"{INDEX}: services card marker not found")
        text = text.replace(services_marker, services_marker + NEIGHBOR_CARD)
        changed = True
    if changed:
        INDEX.write_text(text, encoding="utf-8")
    return changed


def patch_js():
    text = JS.read_text(encoding="utf-8")
    changed = False
    if "function refreshTakEnrollmentStatus" not in text:
        marker = "/* --- Services card --- */"
        if marker not in text:
            raise RuntimeError(f"{JS}: services marker not found")
        text = text.replace(marker, DP_JS + marker)
        changed = True
    elif "refreshTakEnrollmentStatus();" not in text.split("function refreshTakEnrollmentStatus", 1)[1]:
        text = text.replace("showCurrentTls();\n            refreshServices();", "showCurrentTls();\n            refreshServices();\n            refreshTakEnrollmentStatus();")
        changed = True
    if "function importEnrollmentUrl" not in text:
        marker = "/* --- Services card --- */"
        if marker not in text:
            raise RuntimeError(f"{JS}: services marker not found")
        text = text.replace(marker, DP_JS + marker)
        changed = True
    if "function refreshNeighbors" not in text:
        marker = "/* --- Services card --- */"
        if marker not in text:
            raise RuntimeError(f"{JS}: services marker not found")
        text = text.replace(marker, NEIGHBOR_JS + marker)
        changed = True
    listener = '$("btn-tls-upload").addEventListener("click", installTls);'
    dp_listener = '$("btn-dp-upload").addEventListener("click", importDataPackage);'
    enrollment_listener = '$("btn-enrollment-import").addEventListener("click", importEnrollmentUrl);'
    refresh_listener = '$("btn-tak-refresh").addEventListener("click", refreshTakEnrollmentStatus);'
    neighbors_listener = '$("btn-neighbors-refresh").addEventListener("click", refreshNeighbors);'
    if dp_listener not in text:
        if listener not in text:
            raise RuntimeError(f"{JS}: TLS upload listener marker not found")
        text = text.replace(listener, listener + "\n" + dp_listener)
        changed = True
    if enrollment_listener not in text:
        anchor = dp_listener if dp_listener in text else listener
        if anchor not in text:
            raise RuntimeError(f"{JS}: upload listener marker not found")
        text = text.replace(anchor, anchor + "\n" + enrollment_listener)
        changed = True
    if refresh_listener not in text:
        anchor = enrollment_listener if enrollment_listener in text else dp_listener
        if anchor not in text:
            raise RuntimeError(f"{JS}: refresh listener marker not found")
        text = text.replace(anchor, anchor + "\n" + refresh_listener)
        changed = True
    if neighbors_listener not in text:
        anchor = refresh_listener if refresh_listener in text else listener
        if anchor not in text:
            raise RuntimeError(f"{JS}: neighbor refresh listener marker not found")
        text = text.replace(anchor, anchor + "\n" + neighbors_listener)
        changed = True
    if "setInterval(refreshNeighbors, 8000);" not in text:
        text = text.rstrip() + "\nsetInterval(refreshNeighbors, 8000);\n"
        changed = True
    watch_marker = "    showCurrentTls();\n});"
    watch_block = text.split("configFile.watch", 1)[1].split("});", 1)[0]
    if "refreshTakEnrollmentStatus();" not in watch_block:
        if watch_marker not in text:
            raise RuntimeError(f"{JS}: config watch marker not found")
        text = text.replace(watch_marker, "    showCurrentTls();\n    refreshTakEnrollmentStatus();\n});")
        changed = True
    if "refreshNeighbors();" not in text.split("configFile.watch", 1)[1].split("});", 1)[0]:
        marker = "    refreshTakEnrollmentStatus();"
        if marker not in text:
            raise RuntimeError(f"{JS}: neighbor watch marker not found")
        text = text.replace(marker, marker + "\n    refreshNeighbors();", 1)
        changed = True
    if changed:
        JS.write_text(text, encoding="utf-8")
    return changed


def patch_css():
    text = CSS.read_text(encoding="utf-8")
    additions = []
    if ".aos-status-table" not in text:
        additions.append(".aos-status-table { margin: 0.7rem 0 1rem; }")
        additions.append(".aos-status-table td:first-child { width: 12rem; color: var(--aos-muted); }")
    if ".aos-upload-row" not in text:
        additions.append(".aos-upload-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: end; }")
        additions.append(".aos-file-label { flex: 1 1 18rem; }")
        additions.append('.aos-file-label input[type="file"] { display: block; margin-top: 0.3rem; font-weight: 400; }')
        additions.append('.aos-file-label textarea { display: block; box-sizing: border-box; width: 100%; margin-top: 0.3rem; font: inherit; font-family: monospace; }')
    if ".aos-section-head" not in text:
        additions.append(".aos-section-head { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; }")
        additions.append(".aos-section-head h2 { margin: 0; }")
        additions.append(".aos-icon-btn { width: 2.2rem; height: 2.2rem; border: 1px solid var(--aos-accent); border-radius: 5px; background: var(--aos-panel-2); color: var(--aos-accent-dark); cursor: pointer; font-size: 1.2rem; line-height: 1; }")
        additions.append(".aos-table-scroll { width: 100%; overflow-x: auto; }")
        additions.append(".aos-neighbor-summary { margin: 0.6rem 0 0.75rem; color: var(--aos-muted); font-size: 0.9rem; }")
        additions.append(".aos-neighbor-table { min-width: 48rem; }")
    if not additions:
        return False
    CSS.write_text(text.rstrip() + "\n" + "\n".join(additions) + "\n", encoding="utf-8")
    return True


def main():
    if not PLUGIN_DIR.is_dir():
        raise SystemExit("cockpit-aryaos plugin directory not found; package not installed?")
    changed = [patch_index(), patch_js(), patch_css()]
    for path in (INDEX, JS, CSS):
        path.chmod(0o644)
    print("patched cockpit-aryaos overlay UI" if any(changed) else "cockpit-aryaos overlay UI already present")


if __name__ == "__main__":
    main()
