<?xml version="1.0" encoding="utf-8"?>
<!--
AryaOS default zone. Explicit inbound allowlist for everything a field unit
serves; all other inbound traffic is rejected. dhcp/dns are only answered
while comitup runs its onboarding hotspot (dnsmasq is not otherwise active);
Bluetooth PAN (pan0) clients also get their lease through dhcp here.
Loopback traffic is implicitly accepted by firewalld.
Managed in Cockpit: Networking -> Firewall.

NO forward element: this is an appliance, not a router. Intra-zone forwarding is
deliberately OFF so a client on the WiFi onboarding hotspot (wlan0) or the
Bluetooth PAN (pan0) can reach the box's own services but is NEVER routed or
bridged onto the wired ethernet/upstream. This holds even when something else
(Docker, Tailscale) turns on net.ipv4.ip_forward: with no intra-zone forward
rule, wlan0->eth0 / pan0->eth0 forwarding falls through to the zone's reject.
Docker's own container forwarding is unaffected (it lives in the docker zone).
-->
<!-- deliberately NO forward element — see note above (AP/PAN must not gateway to eth) -->
<zone>
  <short>AryaOS</short>
  <description>AryaOS field appliance: web portal/Cockpit, SSH, sensor dashboards, TAK Mesh SA, and WiFi/Bluetooth onboarding.</description>
  <service name="ssh"/>
  <service name="http"/>
  <service name="https"/>
  <service name="mdns"/>
  <service name="dhcp"/>
  <service name="dhcpv6-client"/>
  <service name="dns"/>
  <service name="aryaos-mesh-sa"/>
  <!-- Node-RED (:1880) is NOT opened on the LAN: it binds loopback and is reached
       only via the authenticated HTTPS reverse proxy at /nr (lighttpd). Exposing
       the flow editor (arbitrary code execution) on the wired LAN is unnecessary
       attack surface for a field appliance. -->
  <service name="aryaos-ais-catcher"/>
  <!-- aryaos-comitup (9080 onboarding captive portal) is intentionally NOT opened
       on the wired LAN: it is only needed on the onboarding radios (Wi-Fi hotspot +
       Bluetooth PAN), which get it via the aryaos-hotspot zone. comitup-web binds
       0.0.0.0, so the firewall is what scopes it; LAN admin is via Cockpit. -->
  <service name="ntp"/>
</zone>
