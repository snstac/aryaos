# CloudTAK browser client for AryaOS /cloudtak/ (built from upstream api/web).
# SPDX-License-Identifier: Apache-2.0

FROM node:24 AS build

ARG CLOUDTAK_SA_REPO=https://github.com/snstac/CloudTAK-SA
ARG CLOUDTAK_SA_REF=copilot/add-shim-for-cloudtak-client

WORKDIR /src
RUN git clone --depth 1 --branch "${CLOUDTAK_SA_REF}" "${CLOUDTAK_SA_REPO}" .

WORKDIR /src/api/web
RUN npm ci
COPY patch-aryaos-subpath.mjs /patch-aryaos-subpath.mjs
RUN node /patch-aryaos-subpath.mjs .
RUN npm run build

FROM nginx:alpine

COPY nginx-cloudtak-web.conf /etc/nginx/conf.d/default.conf
COPY --from=build /src/api/web/dist /usr/share/nginx/html

EXPOSE 80
