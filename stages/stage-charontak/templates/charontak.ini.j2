[charontak]
DEBUG = false

[lane:local-to-mesh]
enabled = true
mode = forward
ingress_cot_url = {{ charontak_ingress_cot_url }}
egress_cot_url = {{ charontak_egress_cot_url }}
PYTAK_NO_HELLO = true

[lane:local-to-takserver]
enabled = false
mode = forward
ingress_cot_url = {{ charontak_ingress_cot_url }}
egress_cot_url = tls://takserver.example.com:8089
PYTAK_NO_HELLO = true
