# Copy to playbooks/dragonball-secret.yml (gitignored) when gba needs a sudo password:
#   cp playbooks/dragonball-secret.yml.example playbooks/dragonball-secret.yml
#   chmod 600 playbooks/dragonball-secret.yml
#   # edit ansible_become_password
#
# Deploy:
#   ansible-playbook -i inventory.yml playbooks/readsb-adsbcot-generic.yml \
#     --limit dragonball -e @playbooks/dragonball-secret.yml
---
ansible_become_password: "REPLACE_WITH_SUDO_PASSWORD"
